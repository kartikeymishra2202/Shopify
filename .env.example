# Django
DJANGO_ENV=development
DJANGO_SECRET_KEY=replace-with-strong-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Shared database (Django + FastAPI chat)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT used by ChatService_FastApi auth_handler.py
ALGORITHM=HS256

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=replace-with-app-password
DEFAULT_FROM_EMAIL=noreply@example.com

# Frontend callback URL used by backend auth flow
FRONTEND_URL=http://localhost:5173

# Auth0 (backend)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_REDIRECT_URI=http://localhost:5173/login
AUTH0_AUDIENCE=https://your-api-audience

# Frontend public env vars (safe to expose in browser, but keep per-environment)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id
VITE_AUTH0_REDIRECT_URI=http://localhost:5173/login
VITE_MIXPANEL_TOKEN_DEV=your-mixpanel-dev-token
VITE_MIXPANEL_TOKEN_PROD=your-mixpanel-prod-token
